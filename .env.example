# =============================================================================
# Data Platform connection (use private Railway URL in production)
# =============================================================================
DATA_PLATFORM_URL=http://localhost:8000
DATA_PLATFORM_ADMIN_TOKEN=your-admin-token
DATA_PLATFORM_API_TOKEN=your-api-token

# =============================================================================
# LLM -- for agent reasoning, tool calling, code generation
#
# These go through Requesty (or any OpenAI-compatible proxy).
# CrewAI reads OPENAI_API_KEY and OPENAI_API_BASE from env automatically.
# =============================================================================
OPENAI_API_KEY=your-requesty-api-key
OPENAI_API_BASE=https://router.requesty.ai/v1
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Embedder -- for Memory vectors + Knowledge RAG
#
# Embedding calls are SEPARATE from LLM calls. By default they go directly
# to OpenAI (not through Requesty), because:
#   1. Requesty may not support embedding models
#   2. Embedding calls are high-volume; direct connection avoids proxy overhead
#
# If Requesty DOES support embeddings, set EMBEDDER_API_BASE to Requesty URL.
# =============================================================================
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small
EMBEDDER_API_KEY=sk-your-actual-openai-key
# EMBEDDER_API_BASE=              # leave empty for direct OpenAI
# EMBEDDER_API_BASE=https://router.requesty.ai/v1  # uncomment if Requesty supports embeddings

# Or override everything with raw JSON:
# EMBEDDER_CONFIG_JSON={"provider": "ollama", "config": {"model_name": "mxbai-embed-large", "url": "http://localhost:11434/api/embeddings"}}

# =============================================================================
# Storage (Railway volume in production)
# =============================================================================
CREWAI_STORAGE_DIR=./.crewai_storage
