# =============================================================================
# Data Platform connection (use private Railway URL in production)
# =============================================================================
DATA_PLATFORM_URL=http://localhost:8000
DATA_PLATFORM_ADMIN_TOKEN=your-admin-token
DATA_PLATFORM_API_TOKEN=your-api-token

# =============================================================================
# LLM -- for agent reasoning, tool calling, code generation
# =============================================================================
OPENAI_API_KEY=your-requesty-api-key
OPENAI_API_BASE=https://router.requesty.ai/v1
OPENAI_BASE_URL=https://router.requesty.ai/v1
OPENAI_MODEL=openai/gpt-5.4-nano

# =============================================================================
# Embedder -- for Memory vectors + Knowledge RAG
# =============================================================================
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=openai/text-embedding-3-small
EMBEDDER_API_KEY=your-embedder-api-key
EMBEDDER_API_BASE=https://router.requesty.ai/v1

# =============================================================================
# Storage (Railway volume in production)
# =============================================================================
CREWAI_STORAGE_DIR=./.crewai_storage
